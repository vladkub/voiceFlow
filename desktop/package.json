{
  "name": "voiceflow-desktop",
  "version": "1.0.20",
  "description": "VoiceFlow desktop wrapper",
  "main": "main.js",
  "author": "VoiceFlow",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "icons": "node scripts/generate-icons.mjs",
    "predist:portable": "node scripts/generate-icons.mjs",
    "predist:installer": "node scripts/generate-icons.mjs",
    "predist:dir": "node scripts/generate-icons.mjs",
    "predist:mac": "node scripts/generate-icons.mjs && node scripts/fetch-blackhole-pkg.mjs && node scripts/chmod-mac-installer.mjs",
    "dist:installer": "electron-builder --win nsis",
    "dist:portable": "electron-builder --win portable",
    "dist:dir": "electron-builder --dir",
    "dist:mac": "electron-builder --mac dmg",
    "publish:installer": "node scripts/publish-installer.mjs",
    "publish:mac": "node scripts/publish-mac.mjs"
  },
  "devDependencies": {
    "electron": "37.10.3",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.33.5"
  },
  "build": {
    "appId": "com.voiceflow.desktop",
    "productName": "Voice Translator",
    "electronVersion": "37.10.3",
    "directories": {
      "output": "dist",
      "buildResources": "icons"
    },
    "files": [
      "main.js",
      "blackhole-mac.js",
      "preload.js",
      "chat-layout-fix.css",
      "region-select.html",
      "region-select-preload.js",
      "index.html",
      "renderer.js",
      "styles.css",
      "favicon.svg"
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "extraResources": [
      {
        "from": "../public/login.html",
        "to": "public/login.html"
      },
      {
        "from": "../frontend/app.js",
        "to": "frontend/app.js"
      },
      {
        "from": "build/vbcable-bootstrap.ps1",
        "to": "vbcable-bootstrap.ps1"
      }
    ],
    "icon": "icons/icon.png",
    "win": {
      "icon": "icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "icons/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "artifactName": "Voice-Translator.dmg",
      "extraResources": [
        {
          "from": "build/blackhole-bootstrap.sh",
          "to": "blackhole-bootstrap.sh"
        },
        {
          "from": "build/BlackHole2ch-0.6.1.pkg",
          "to": "BlackHole2ch.pkg"
        }
      ]
    },
    "dmg": {
      "title": "TalkPilot ${version}",
      "contents": [
        {
          "x": 130,
          "y": 180
        },
        {
          "x": 410,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 270,
          "y": 360,
          "type": "file",
          "path": "build/Install TalkPilot.command",
          "name": "Install TalkPilot.command"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "allowElevation": false,
      "runAfterFinish": true,
      "artifactName": "Voice-Translator-Setup.exe",
      "include": "build/installer.nsh"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://talkpilot.pro/downloads"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "uiohook-napi": "^1.5.4"
  }
}
